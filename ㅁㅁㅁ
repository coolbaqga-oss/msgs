  c.classList.add("on"); state.subj = c.dataset.subj; state.idx = 0; render();
});

document.querySelectorAll(".chip[data-filter]").forEach(c => c.onclick = () => {
  const f = c.dataset.filter;
  if(f === "freq"){ state.freqOnly = !state.freqOnly; c.classList.toggle("on"); }
  if(f === "wrong"){ state.wrongOnly = !state.wrongOnly; c.classList.toggle("on"); }
  if(f === "shuffle"){ state.shuffled = !state.shuffled; c.classList.toggle("on"); }
  if(f === "wrongnote"){ state.wrongnoteOnly = !state.wrongnoteOnly; c.classList.toggle("on"); }
  state.idx = 0; render();
});

// 모드 탭 클릭 이벤트 (3가지 모드 분기)
document.querySelectorAll(".mode-tab").forEach(t => t.onclick = () => {
  document.querySelectorAll(".mode-tab").forEach(x => x.classList.remove("on"));
  t.classList.add("on"); 
  state.mode = t.dataset.mode; 
  state.idx = 0; 
  
  if(state.mode === 'study' && examData.active) {
      clearInterval(examData.timerId); examData.active = false;
  }
  render();
});

document.getElementById("reset").onclick = () => {
  progress = {}; localStorage.removeItem("moksagosi_prog");
  wrongNotes = {}; localStorage.removeItem("wrongNotes");
  state.idx = 0; render(); 
  alert("학습 기록 및 오답노트가 모두 초기화되었습니다.");
};

document.addEventListener("keydown", e => {
  if (state.mode !== 'study') return; 
  if (e.key === "ArrowRight") { const n = document.getElementById("next-btn"); if (n) n.click(); }
  if (e.key === "ArrowLeft") { const p = document.getElementById("prev-btn"); if (p) p.click(); }
  if (e.key >= "1" && e.key <= "5") {
    const idx = parseInt(e.key) - 1;
    const btn = document.getElementById(`opt-${idx}`);
    if (btn) btn.click();
  }
});

render();
</script>
</body>
</html>
