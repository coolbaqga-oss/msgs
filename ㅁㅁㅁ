// ==========================================
// 2. 상태 및 로컬 스토리지 관리
// ==========================================
let state = {
  year: 'all', 
  subj: 'all',
  mode: 'study', // 'study', 'yearly', 'exam'
  idx: 0,
  freqOnly: false,
  wrongOnly: false,
  shuffled: false,
  wrongnoteOnly: false
};

let progress = JSON.parse(localStorage.getItem("moksagosi_prog")) || {};
let wrongNotes = JSON.parse(localStorage.getItem("wrongNotes")) || {};
let list = [];
let showAns = false;

// 모의고사/연도별기출 공용 데이터 객체
let examData = { active: false, finished: false, isYearly: false, list: [], answers: [], timeLeft: 1200, timerId: null };

const getQId = (q) => `${q.year}-${q.subj}-${q.no || q.q.slice(0, 10)}`;

function save() {
  localStorage.setItem("moksagosi_prog", JSON.stringify(progress));
}

// ==========================================
// 3. UI 렌더링 및 필터링 로직
// ==========================================
function render() {
  // 모드별 분기
  if (state.mode === 'yearly') return renderYearly();
  if (state.mode === 'exam') return renderExam();

  // --- 이하 학습 모드(study) 로직 ---
  const cArea = document.getElementById("content-area");
  cArea.innerHTML = "";
  showAns = false;

  // 필터링 적용
  list = allQuestions.filter(q => {
    if (!state.freqOnly && state.year !== 'all' && q.year !== state.year && q.year !== '빈출') return false;
    if (state.freqOnly && q.year !== '빈출') return false;
    if (state.subj !== 'all' && q.subj !== state.subj) return false;
    
    if (state.wrongOnly) {
      const rec = progress[getQId(q)];
      if (!rec || rec === 'O') return false;
    }
    // 약점 오답 필터 (3회 이상 틀린 문제만)
    if (state.wrongnoteOnly) {
      if (!wrongNotes[getQId(q)] || wrongNotes[getQId(q)].count < 3) return false;
    }
    return true;
  });

  // 셔플 및 빈출 2배수 적용 (학습 모드)
  if (state.shuffled) {
    let pool = [];
    list.forEach(q => {
      pool.push(q);
      if (state.freqOnly && q.year === '빈출') pool.push(q);
    });
    list = pool.sort(() => Math.random() - 0.5);
  }

  updateDashboard();

  if (list.length === 0) {
    cArea.innerHTML = `<div class="card" style="text-align:center; padding:40px;">조건에 맞는 문제가 없습니다.</div>`;
    return;
  }
  
  if (state.idx >= list.length) state.idx = 0;
  if (state.idx < 0) state.idx = list.length - 1;

  renderStudy(cArea);
}

// 과목별 정답률 계산
function updateDashboard() {
  let stats = { '성경': { t: 0, c: 0 }, '교회사': { t: 0, c: 0 }, '헌법': { t: 0, c: 0 } };
  
  allQuestions.forEach(q => {
    const qid = getQId(q);
    if (progress[qid] === 'O' || progress[qid] === 'X') {
      if (stats[q.subj]) {
          stats[q.subj].t++;
          if (progress[qid] === 'O') stats[q.subj].c++;
      }
    }
  });

  ['성경', '교회사', '헌법'].forEach(subj => {
    const el = document.getElementById(`score-${subj === '성경' ? 'bible' : subj === '교회사' ? 'history' : 'law'}`);
    if (el) {
      const percent = stats[subj].t === 0 ? 0 : Math.round((stats[subj].c / stats[subj].t) * 100);
      el.textContent = `${percent}%`;
    }
  });
}

function showToast(msg) {
  const x = document.getElementById("toast");
  x.innerHTML = msg;
  x.className = "show";
  setTimeout(() => { x.className = x.className.replace("show", ""); }, 3000);
}

function scrollToQuestion() {
  const el = document.querySelector('.card');
  if (el) {
    const y = el.getBoundingClientRect().top + window.pageYOffset - 20;
    window.scrollTo({ top: y < 0 ? 0 : y, behavior: 'auto' });
  }
}

// ==========================================
// [학습 모드] 렌더링
// ==========================================
function renderStudy(cArea) {
  const q = list[state.idx];
  const qid = getQId(q);
  const rec = progress[qid];
  
  let html = `
    <div class="card">
      <div class="q-meta">${state.idx + 1} / ${list.length} &nbsp;|&nbsp; ${q.year}년 ${q.subj} ${q.no ? q.no+'번' : ''}</div>
      <div class="q-text">Q. ${q.q}</div>
      <div class="options">
  `;
  
  q.opts.forEach((opt, i) => {
    html += `<div class="opt" id="opt-${i}">${i + 1}. ${opt}</div>`;
  });
  
  html += `
      </div>
      <div class="ans-box" id="ans-box">
        <strong>정답: ${q.a + 1}번</strong><br><br>
        ${q.e}
      </div>
    </div>
    <div class="nav-btns">
      <button class="nav-btn" id="prev-btn">◀ 이전</button>
      <button class="nav-btn primary" id="next-btn">다음 ▶</button>
    </div>
  `;
  
  cArea.innerHTML = html;
  
  // 마킹 정보 표시
  if (rec === 'O') document.querySelector('.q-meta').innerHTML += ` <span style="color:var(--green)">[맞힘]</span>`;
  if (rec === 'X') document.querySelector('.q-meta').innerHTML += ` <span style="color:var(--red)">[틀림]</span>`;
  
  q.opts.forEach((opt, i) => {
    document.getElementById(`opt-${i}`).onclick = () => {
      if (showAns) return;
      showAns = true;
      
      if (i === q.a) {
        progress[qid] = 'O';
      } else {
        progress[qid] = 'X';
        
        // 오답 노트 카운트 증가
        if (!wrongNotes[qid]) wrongNotes[qid] = { count: 0, last: '' };
        wrongNotes[qid].count++;
        wrongNotes[qid].last = new Date().toISOString().split('T')[0];
        localStorage.setItem("wrongNotes", JSON.stringify(wrongNotes));
        
        // ✨ 에빙하우스 오답 자동 반복 (틀리면 맨 뒤에 다시 추가)
        list.push(q);
        showToast("오답 노트에 기록되었습니다.<br>이 문제는 뒤에서 다시 출제됩니다.");
      }
      save();
      updateDashboard();
      
      document.getElementById(`opt-${q.a}`).classList.add("correct");
      if (i !== q.a) document.getElementById(`opt-${i}`).classList.add("wrong");
      document.getElementById("ans-box").style.display = "block";
    };
  });
  
  document.getElementById("prev-btn").onclick = () => { state.idx--; render(); scrollToQuestion(); };
  document.getElementById("next-btn").onclick = () => { state.idx++; render(); scrollToQuestion(); };
}

