// [연도별 기출] 렌더링
// ==========================================
function renderYearly() {
  const cArea = document.getElementById("content-area");
  cArea.innerHTML = "";

  if (!examData.active && !examData.finished) {
    if (state.year === 'all') {
        cArea.innerHTML = `
        <div class="card" style="text-align:center; padding:40px 20px;">
            <h2 style="color:var(--burgundy); margin-bottom:15px;">📚 연도별 기출 풀기</h2>
            <p>상단 필터에서 풀고자 하는 <b>[연도]</b>와 <b>[과목]</b>을 선택해 주세요.</p>
            <p style="color:var(--muted); font-size:0.9rem; margin-top:10px;">(예: 2025 기출 / 전체 과목)</p>
        </div>`;
        return;
    }

    let currentList = allQuestions.filter(q => q.year === state.year && (state.subj === 'all' || q.subj === state.subj));
    
    cArea.innerHTML = `
      <div class="card" style="text-align:center; padding:40px 20px;">
        <h2 style="color:var(--burgundy); margin-bottom:15px;">📚 ${state.year}년도 기출 풀기</h2>
        <p>선택하신 [<b>${state.subj === 'all' ? '전체 과목' : state.subj}</b>] 총 <b>${currentList.length}문제</b>를<br>실제 시험지 번호 순서대로 풀어봅니다.</p>
        <p style="color:var(--muted); font-size:0.9rem; margin-top:10px;">(본 모드는 제한 시간이 없습니다.)</p>
        <button onclick="startExamMode(true)" style="margin-top:30px; padding:12px 24px; background:var(--ink); color:#fff; border:none; border-radius:8px; font-size:1.1rem; cursor:pointer;">기출 풀기 시작</button>
      </div>`;
    return;
  }

  drawExamUI(cArea, true); // true = yearly mode
}

// ==========================================
// [실전 모의고사] 렌더링 (랜덤 33문제)
// ==========================================
function renderExam() {
  const cArea = document.getElementById("content-area");
  cArea.innerHTML = "";

  if (!examData.active && !examData.finished) {
    let subjText = state.subj === 'all' ? '전체 과목 믹스' : state.subj;
    cArea.innerHTML = `
      <div class="card" style="text-align:center; padding:40px 20px;">
        <h2 style="color:var(--red); margin-bottom:15px;">⏳ 실전 모의고사 (33제)</h2>
        <p>선택된 필터 내에서 [<b>${subjText}</b>]<br><b>랜덤 33문제</b>가 섞여서 출제됩니다.</p>
        <p style="color:var(--muted); font-size:0.9rem; margin-top:10px;">실제 목사고시와 동일하게 20분 타이머가 작동합니다.</p>
        <button onclick="startExamMode(false)" style="margin-top:30px; padding:12px 24px; background:var(--burgundy); color:#fff; border:none; border-radius:8px; font-size:1.1rem; cursor:pointer;">모의고사 시작</button>
      </div>`;
    return;
  }

  drawExamUI(cArea, false); // false = random exam mode
}

// 공통 시험/모의고사 UI 그리기 함수
function drawExamUI(cArea, isYearly) {
  if (examData.finished) {
    let score = 0;
    examData.list.forEach((q, idx) => { if (examData.answers[idx] === q.a) score++; });
    const finalScore = Math.round((score / examData.list.length) * 100);

    let html = `
      <div class="exam-result-box">
        <h2>${isYearly ? state.year+'년 기출 결과' : '모의고사 결과'}</h2>
        <h1 style="color:var(--burgundy); font-size:3rem; margin:10px 0;">${finalScore}점</h1>
        <p>${examData.list.length}문제 중 ${score}문제 정답</p>
        <button onclick="resetExamMode()" style="margin-top:15px; padding:8px 16px; border:1px solid var(--burgundy); background:transparent; color:var(--burgundy); border-radius:4px; cursor:pointer;">종료하고 돌아가기</button>
      </div>
      <h3 style="margin-bottom:10px; color:var(--red);">틀린 문제 오답 노트</h3>
    `;

    let hasWrong = false;
    examData.list.forEach((q, idx) => {
      if (examData.answers[idx] !== q.a) {
        hasWrong = true;
        html += `
          <div class="card" style="margin-top:15px; border-left:4px solid var(--red);">
            <div class="q-meta">${q.year}년 ${q.subj} ${q.no ? q.no+'번' : ''} <span class="wrong-badge">내가 고른 답: ${examData.answers[idx] !== undefined ? examData.answers[idx]+1+'번' : '미체크'}</span></div>
            <div class="q-text" style="font-size:1rem; margin-bottom:10px;">Q. ${q.q}</div>
            <div class="ans-box" style="margin-top:10px; display:block; padding:10px;">
              <strong>정답: ${q.a + 1}번</strong><br>
              ${q.e}
            </div>
          </div>`;
      }
    });
    
    if(!hasWrong) html += `<div class="card" style="text-align:center; font-weight:bold;">🎉 완벽합니다! 모두 맞았습니다.</div>`;
    
    cArea.innerHTML = html;
    window.scrollTo(0, 0);
    return;
  }

  // 문제 푸는 화면 (타이머 유무)
  let timerHtml = "";
  if (!isYearly) {
      const min = Math.floor(examData.timeLeft / 60).toString().padStart(2, '0');
      const sec = (examData.timeLeft % 60).toString().padStart(2, '0');
      timerHtml = `<div class="exam-timer">남은 시간 - ${min}:${sec}</div>`;
  } else {
      timerHtml = `<div class="exam-timer" style="background:var(--ink);">📚 ${state.year}년 기출 풀이 (총 ${examData.list.length}문제)</div>`;
  }
  
  let html = timerHtml;
  
  examData.list.forEach((q, qIndex) => {
    html += `
      <div class="card" style="margin-bottom:20px; padding:20px;">
        <div class="q-meta">${qIndex + 1}번. (${q.year} ${q.subj} ${q.no ? q.no+'번' : ''})</div>
        <div class="q-text" style="font-size:1.1rem;">${q.q}</div>
        <div class="options">
          ${q.opts.map((opt, i) => `
            <div class="opt" 
                 onclick="markExamAnswer(${qIndex}, ${i})" 
                 style="cursor:pointer; padding:10px; border:1px solid var(--line); margin-bottom:5px; border-radius:4px; ${examData.answers[qIndex] === i ? 'background:var(--burgundy-soft); color:white; border-color:var(--burgundy);' : ''}">
              ${i + 1}. ${opt}
            </div>
          `).join('')}
        </div>
      </div>`;
  });

  html += `<button class="exam-submit-btn" onclick="submitExamMode()">답안 제출 및 채점하기</button>`;
  cArea.innerHTML = html;
}

// 시험 시작 컨트롤러
function startExamMode(isYearly) {
  let pool = [];

  if (isYearly) {
      // 연도별: 선택 연도/과목에 맞춰 기출 번호(no) 순서대로 정렬
      const subjOrder = {"성경":1, "교회사":2, "헌법":3};
      let currentList = allQuestions.filter(q => q.year === state.year && (state.subj === 'all' || q.subj === state.subj));
      pool = currentList.sort((a, b) => {
          if(subjOrder[a.subj] !== subjOrder[b.subj]) return subjOrder[a.subj] - subjOrder[b.subj];
          return (a.no || 0) - (b.no || 0);
      });
  } else {
      // 랜덤 모의고사: 33문제 추출
      let currentList = allQuestions.filter(q => {
        if (!state.freqOnly && state.year !== 'all' && q.year !== state.year && q.year !== '빈출') return false;
        if (state.freqOnly && q.year !== '빈출') return false;
        if (state.subj !== 'all' && q.subj !== state.subj) return false;
        return true;
      });
      
      // '전체 과목'일 경우 각 과목별로 11문제씩 공평하게 뽑아 섞음
      if (state.subj === 'all' && currentList.length >= 33) {
          let bible = currentList.filter(q => q.subj === '성경').sort(()=>Math.random()-0.5).slice(0,11);
          let history = currentList.filter(q => q.subj === '교회사').sort(()=>Math.random()-0.5).slice(0,11);
          let law = currentList.filter(q => q.subj === '헌법').sort(()=>Math.random()-0.5).slice(0,11);
          pool = [...bible, ...history, ...law].sort(()=>Math.random()-0.5);
      } else {
          pool = [...currentList].sort(()=>Math.random()-0.5).slice(0, 33);
      }
  }
  
  examData = { 
      active: true, 
      finished: false, 
      isYearly: isYearly,
      list: pool, 
      answers: new Array(pool.length).fill(undefined), 
      timeLeft: 1200, 
      timerId: null 
  };
  
  if (!isYearly) {
      examData.timerId = setInterval(() => {
        examData.timeLeft--;
        if (examData.timeLeft <= 0) {
          clearInterval(examData.timerId);
          alert("시간이 종료되었습니다. 자동 채점합니다.");
          submitExamMode();
        } else {
          render(); // 타이머 갱신
        }
      }, 1000);
  }
  
  render();
}

function markExamAnswer(qIndex, optIndex) {
  examData.answers[qIndex] = optIndex;
  render(); 
}

function submitExamMode() {
  clearInterval(examData.timerId);
  
  // 틀린 문제 오답노트 자동 등록
  examData.list.forEach((q, idx) => {
    if (examData.answers[idx] !== q.a) {
      const qid = getQId(q);
      if (!wrongNotes[qid]) wrongNotes[qid] = { count: 0, last: '' };
      wrongNotes[qid].count++;
      wrongNotes[qid].last = new Date().toISOString().split('T')[0];
    }
  });
  localStorage.setItem("wrongNotes", JSON.stringify(wrongNotes));
  
  examData.active = false;
  examData.finished = true;
  updateDashboard();
  render();
}

function resetExamMode() {
  examData = { active: false, finished: false, isYearly: false, list: [], answers: [], timeLeft: 1200, timerId: null };
  render();
}

