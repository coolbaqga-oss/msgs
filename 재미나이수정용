  const txt = days <= 0 ? "오늘" : `${days}일 전`;
  el.textContent = `마지막 백업: ${txt}`;
  el.classList.toggle("warn", days >= 7);
}

// 보기 한 줄 = [보기 버튼] + [✕ 소거 토글]. handler는 "checkAns" 또는 "pickExam".
function optionRowsHtml(opts, handler) {
  return opts.map((opt, i) =>
    `<div class="opt-row">
       <button class="opt" onclick="${handler}(${i})">${i + 1}. ${opt}</button>
       <button class="opt-x" title="소거" onclick="toggleEliminate(event, ${i})">✕</button>
     </div>`).join("");
}

// ✕ 토글: 보기를 흐리게 죽이거나 되살린다(채점은 하지 않음). 문제를 넘기면 자동 초기화.
function toggleEliminate(e, i) {
  e.stopPropagation();
  const row = e.currentTarget.closest(".opt-row");
  if (!row) return;
  const opt = row.querySelector(".opt");
  const x = row.querySelector(".opt-x");
  const killed = opt.classList.toggle("eliminated");
  x.classList.toggle("on", killed);
}

// 문제 번호 점프: 카운터를 누르면 그 자리에 입력칸이 열린다.
function openJump() {
  const list = getList(false);
  if (!list.length) return;
  const el = document.getElementById("q-counter");
  if (!el) return;
  el.innerHTML =
    `<span class="jump-wrap" onclick="event.stopPropagation()">
       <input class="jump-input" id="jump-input" type="number" inputmode="numeric"
              min="1" max="${list.length}" value="${state.idx + 1}"
              onkeydown="if(event.key==='Enter')doJump()">
       <span style="color:var(--muted);font-size:.85rem">/ ${list.length}</span>
       <button class="jump-btn" onclick="doJump()">이동</button>
       <button class="jump-btn ghost" onclick="render()">취소</button>
     </span>`;
  const inp = document.getElementById("jump-input");
  if (inp) { inp.focus(); inp.select(); }
}

function doJump() {
  const list = getList(false);
  if (!list.length) return;
  const inp = document.getElementById("jump-input");
  let n = parseInt((inp && inp.value || "").trim(), 10);
  if (isNaN(n)) { showToast("숫자를 입력하세요."); return; }
  n = Math.max(1, Math.min(list.length, n));
  state.idx = n - 1;
  state.lastQid = getQId(list[state.idx]);
  state.lastQids[state.subj] = state.lastQid;
  localStorage.setItem("mok_last", state.lastQid);
  localStorage.setItem("mok_lasts", JSON.stringify(state.lastQids));
  render();
  scrollToSolve();
}

function renderStudy(cArea) {
  const list = getList(false);
  if (list.length === 0) {
    cArea.innerHTML = "<div class='card'>조건에 맞는 문제가 없습니다.</div>";
    updateDashboard();
    return;
  }
  if (state.pendingResume) {
    const resumeQid = state.lastQids[state.subj] || state.lastQid;
    const ri = list.findIndex(item => getQId(item) === resumeQid);
    state.idx = ri >= 0 ? ri : 0;
    state.pendingResume = false;
  } else if (state.idx >= list.length) {
    state.idx = 0;
  }
  const q = list[state.idx];
  const qid = getQId(q);
  state.lastQid = qid;
  state.lastQids[state.subj] = qid;
  localStorage.setItem("mok_last", qid);
  localStorage.setItem("mok_lasts", JSON.stringify(state.lastQids));

  cArea.innerHTML = `
    <div class="nav-btns">
      <button class="nav-btn" onclick="moveIdx(-1)">◀ 이전</button>
      <button class="nav-btn primary" onclick="moveIdx(1)">다음 ▶</button>
    </div>
    <div class="card">
      <div class="q-meta">
        <div><span class="q-counter" id="q-counter" onclick="openJump()">${state.idx + 1} / ${list.length}</span> | ${q.year}년 ${q.subj}</div>
        <div class="meta-right">
          <span class="star" onclick="toggleBm('${qid}')" style="color:${bookmarks[qid] ? 'var(--gold)' : '#ccc'}">★</span>
        </div>
      </div>
      <div class="q-text">${q.q}</div>
      <div id="options-area">
        ${optionRowsHtml(q.opts, "checkAns")}
      </div>
      <div id="fb-slot"></div>
    </div>
  `;
  updateDashboard();
}

function renderExamMode(cArea) {
  if (exam.active && exam.source === "exam") return renderExamScreen(cArea);
  cArea.innerHTML = `
    <div class="card">
      <div class="q-text">모의고사 설정</div>
      <div style="display:flex; gap:10px; margin-bottom:8px;">
        <input id="exam-count" type="number" min="1" step="1" value="${state.examCount || 33}"
          style="flex:1; padding:10px; border-radius:8px; border:1px solid var(--line);" placeholder="문항 수 (기본 33)">
        <select id="exam-time" style="flex:1; padding:10px; border-radius:8px; border:1px solid var(--line);">
          <option value="30">30분</option>
          <option value="40" selected>40분</option>
          <option value="60">60분</option>
        </select>
      </div>
      <div style="font-size:0.85rem; color:var(--muted);">모의고사는 전체 연도에서 균등 섞기 방식으로 출제됩니다.</div>
      <button class="nav-btn primary" style="margin-top:12px;" onclick="startExam()">모의고사 시작</button>
    </div>
  `;
  updateDashboard();
}

function renderYearlyMode(cArea) {
  if (exam.active && exam.source === "yearly") return renderExamScreen(cArea);
  const years = getYearList();
  const allOn = years.length > 0 && state.yearlyYears.length === years.length;
  const count = state.yearlyYears.length ? buildYearlyPoolAll().length : 0;
  cArea.innerHTML = `
    <div class="card">
      <div class="q-text">기출 연도 선택 (복수 선택)</div>
      <div class="filters" id="year-pick-wrap" style="margin-top:10px;">
        <button class="chip pick year-pick ${allOn ? "on" : ""}" onclick="toggleYearPick('all')">전체</button>
        ${years.map(y => `<button class="chip pick year-pick ${state.yearlyYears.includes(y) ? "on" : ""}" onclick="toggleYearPick('${y}')">${y}</button>`).join("")}
      </div>
      <div style="margin-top:10px; font-size:0.85rem; color:var(--muted);">선택 연도: ${state.yearlyYears.length ? state.yearlyYears.join(", ") : "없음"} | 총 ${count}문항</div>
      <button class="nav-btn primary" style="margin-top:12px;" onclick="startYearlyExam()">기출 풀이 시작</button>
    </div>
  `;
  updateDashboard();
}

function toggleYearPick(y) {
  const years = getYearList();
  if (y === "all") {
    if (state.yearlyYears.length === years.length) state.yearlyYears = [];
    else state.yearlyYears = years.slice();
  } else {
    if (state.yearlyYears.includes(y)) state.yearlyYears = state.yearlyYears.filter(v => v !== y);
    else state.yearlyYears.push(y);
  }
  renderYearlyMode(document.getElementById("content-area"));
}

function parseCount(id, defVal) {
  const el = document.getElementById(id);
  if (!el) return defVal;
  const v = parseInt(el.value, 10);
  return (!v || v < 1) ? defVal : v;
}

function startExam() {
  let list = buildExamPool();
  if (!list.length) {
    document.getElementById("content-area").innerHTML = "<div class='card'>조건에 맞는 문제가 없습니다.</div>";
    return;
  }
  let count = parseCount("exam-count", 33);
  state.examCount = count;
  count = Math.min(count, list.length);
  const minutes = parseInt(document.getElementById("exam-time").value, 10);
  startExamWithList(list, count, minutes, "exam", true);
}

function startYearlyExam() {
  if (!state.yearlyYears.length) {
    showToast("연도를 하나 이상 선택하세요.");
    return;
  }
  const list = buildYearlyPoolAll();
  if (!list.length) {
    showToast("선택 연도에 문제가 없습니다.");
    return;
  }
  startExamWithList(list, list.length, null, "yearly", false);
}

function startExamWithList(list, count, minutes, source, timed) {
  const picked = (source === "exam") ? mixByYear(list, count) : list.slice(0, count);
  exam.list = picked;
  exam.answers = [];
  exam.idx = 0;
  exam.active = true;
  exam.source = source;
  exam.timed = timed;
  if (timed) {
    exam.start = Date.now();
    exam.duration = minutes * 60;
    startExamTimer();
  } else {
    exam.start = 0;
    exam.duration = 0;
    clearInterval(exam.timerId);
  }
  renderExamScreen(document.getElementById("content-area"));
}

function renderExamScreen(cArea) {
  const q = exam.list[exam.idx];
  const title = exam.source === "yearly" ? "기출 풀이" : "모의고사";
  const timerHtml = exam.timed
    ? `<div class="exam-timer" id="exam-timer" style="flex:1; position:static;">남은 시간: ${formatTime(getExamLeft())}</div>`
    : `<div class="exam-timer no-timer" style="flex:1; position:static;">시간 제한 없음</div>`;
  cArea.innerHTML = `
    <div style="display:flex; gap:8px; margin-bottom:10px;">
      ${timerHtml}
      <button class="nav-btn" style="flex:0 0 auto; padding:10px 14px;" onclick="stopExam()">종료</button>
    </div>
    <div class="card">
      <div class="q-meta"><div>${title} | ${exam.idx + 1} / ${exam.list.length} | ${q.year}년 ${q.subj}</div></div>
      <div class="q-text">${q.q}</div>
      <div id="options-area">
        ${optionRowsHtml(q.opts, "pickExam")}
      </div>
    </div>
  `;
  scrollToSolve();
}

function stopExam() {
  if (!confirm("시험을 종료하시겠습니까?")) return;
  finishExam("manual");
}

function pickExam(picked) {
  const q = exam.list[exam.idx];
  const qid = getQId(q);
  const isCorrect = picked === q.a;
  exam.answers[exam.idx] = picked;
  recordAnswer(qid, isCorrect);
  if (exam.idx < exam.list.length - 1) {
    exam.idx++;
    renderExamScreen(document.getElementById("content-area"));
  } else {
    finishExam("done");
  }
}

function recordAnswer(qid, isCorrect) {
  updateStats(qid, isCorrect);
  progress[qid] = isCorrect ? "O" : "X";
  if (!isCorrect) saveWrong(qid);
  saveSRS(qid, isCorrect);
  updateStreak();
  saveAll();
  invalidateList();
}

function startExamTimer() {
  clearInterval(exam.timerId);
  exam.timerId = setInterval(() => {
    if (!exam.active || !exam.timed) return;
    const left = getExamLeft();
    const el = document.getElementById("exam-timer");
    if (el) el.textContent = "남은 시간: " + formatTime(left);
    if (left <= 0) finishExam("timeover");
  }, 500);
}

function getExamLeft() {
  const elapsed = Math.floor((Date.now() - exam.start) / 1000);
  return Math.max(0, exam.duration - elapsed);
}

function formatTime(sec) {
  const m = Math.floor(sec / 60);
  const s = sec % 60;
  return `${m}:${s.toString().padStart(2, "0")}`;
}

function finishExam(reason) {
  clearInterval(exam.timerId);
  exam.active = false;

  const total = exam.list.length;
  let correct = 0;
  const wrongItems = [];
  exam.list.forEach((q, i) => {
    const picked = exam.answers[i];
    if (picked === q.a) correct++;
    else wrongItems.push({ q, picked });
  });

  const baseTitle = exam.source === "yearly" ? "기출" : "모의고사";
  const title = reason === "timeover" ? "시간 종료" : (reason === "manual" ? `${baseTitle} 중도 종료` : `${baseTitle} 완료`);
  const score = total ? Math.round((correct / total) * 100) : 0;

  const cArea = document.getElementById("content-area");
  cArea.innerHTML = `
    <div class="card">
      <div class="q-text">${title}</div>
      <div style="font-weight:bold; font-size:1.2rem; margin-bottom:10px;">점수: ${score}점 (${correct}/${total})</div>
      ${wrongItems.length ? `
        <div style="margin-top:10px;">
          ${wrongItems.map(w => `
            <div style="padding:10px; border-top:1px dashed var(--line);">
              <div style="color:var(--gold); font-weight:bold;">오답: ${w.q.year}년 ${w.q.subj}</div>
              <div>${w.q.q}</div>
              <div style="margin-top:6px;">정답: ${w.q.a + 1}번 / 선택: ${w.picked !== undefined ? w.picked + 1 : "미응답"}</div>
              <div style="margin-top:6px; color:var(--muted);">${w.q.e || ""}</div>
            </div>
          `).join("")}
        </div>
      ` : `<div>오답이 없습니다.</div>`}
      <button class="nav-btn primary" style="margin-top:15px;" onclick="render()">다시 돌아가기</button>
    </div>
  `;
  updateDashboard();
}

function checkAns(picked) {
  const list = getList(false);
  const q = list[state.idx];
  const qid = getQId(q);
  const isCorrect = picked === q.a;

  const opts = document.querySelectorAll(".opt");
  opts.forEach(o => { o.classList.add("answered"); o.classList.remove("eliminated"); });
  document.querySelectorAll("#options-area .opt-x").forEach(x => x.style.display = "none");
  opts[picked].classList.add("selected");
  opts[q.a].classList.add("correct");
  if (!isCorrect) opts[picked].classList.add("wrong");

  if (!isCorrect) { saveWrong(qid); saveSRS(qid, false); }
  else { saveSRS(qid, true); }

  const title = isCorrect ? "정답입니다!" : `오답 · 정답은 ${q.a + 1}번`;
  const icon = isCorrect ? "✓" : "✕";
  const expHtml = q.e ? `<div class="fb-exp">${q.e}</div>` : "";
  const tagsHtml = isCorrect ? "" :
    `<div class="fb-tags">${["헷갈림", "암기부족", "실수"].map(t =>
      `<button class="fb-tag" onclick="setTag('${qid}', '${t}')">${t}</button>`).join("")}</div>`;

  const slot = document.getElementById("fb-slot");
  slot.innerHTML = `
    <div class="fb-panel ${isCorrect ? "ok" : "bad"}">
      <div class="fb-head"><div class="fb-icon">${icon}</div><div class="fb-title">${title}</div></div>
      ${expHtml}
      ${tagsHtml}
      <button class="fb-gemini" id="fb-gemini-btn">✨ 이 문제 AI에게 물어보기</button>
      <button class="fb-next" onclick="moveIdx(1)">계속하기 ▶</button>
    </div>`;

  // Gemini 버튼: 문제를 복사하고 Gemini를 연다 (특수문자 escape 회피 위해 JS로 연결)
  const gprompt =
    `다음은 대한예수교장로회(통합) 목사고시 ${q.subj} 기출문제야. 쉽게 풀어서 설명해주고, 정답인 이유와 다른 보기가 오답인 이유도 알려줘.\n\n` +
    `[문제] ${plainText(q.q)}\n` +
    q.opts.map((o, i) => `${i + 1}. ${plainText(o)}`).join("\n") +
    `\n\n정답: ${q.a + 1}번`;
  const gbtn = document.getElementById("fb-gemini-btn");
  if (gbtn) gbtn.onclick = () => askGemini(gprompt);

  updateStats(qid, isCorrect);
  progress[qid] = isCorrect ? "O" : "X";
  updateStreak();
  saveAll();
  invalidateList();
  updateDashboard();

  // 피드백 패널(계속하기 버튼)이 화면에 들어오도록 살짝 스크롤
  requestAnimationFrame(() => {
    const y = slot.getBoundingClientRect().bottom + window.pageYOffset - window.innerHeight + 16;
    if (y > window.pageYOffset) smoothScrollTo(y);
  });
}

// HTML 제거해 순수 텍스트만
function plainText(html) {
  const d = document.createElement("div");
  d.innerHTML = html == null ? "" : String(html);
  return (d.textContent || d.innerText || "").replace(/\s+/g, " ").trim();
}

// 현재 문제를 Google AI 모드(Gemini 기반)로 보낸다 — 질문이 자동 입력·실행됨
function askGemini(promptText) {
  const url = "https://www.google.com/search?udm=50&q=" + encodeURIComponent(promptText);
  // 아이패드·PWA·팝업차단에서도 열리도록 일반 링크 클릭 방식 사용 (window.open은 막힐 수 있음)
  try {
    const a = document.createElement("a");
    a.href = url;
    a.target = "_blank";
    a.rel = "noopener noreferrer";
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    return;
  } catch (e) {}
  try { if (window.open(url, "_blank")) return; } catch (e) {}
  window.location.href = url;  // 최후: 같은 탭에서 열기(돌아오면 이어풀기로 복귀)
}

// 공용 스크롤 (부드러운 스크롤 미지원 기기에선 즉시 이동)
function smoothScrollTo(y) {
  y = Math.max(0, y);
  const smooth = "scrollBehavior" in document.documentElement.style;
  if (smooth) window.scrollTo({ top: y, behavior: "smooth" });
  else window.scrollTo(0, y);
}

function scrollToSolve() {
  const el = document.getElementById("content-area");
  if (!el) return;
  const doIt = () => smoothScrollTo(el.getBoundingClientRect().top + window.pageYOffset - 8);
  // 새로 렌더된 레이아웃이 안정된 뒤 스크롤 (iOS 타이밍 대응)
  requestAnimationFrame(() => requestAnimationFrame(() => setTimeout(doIt, 30)));
}

function moveIdx(step) {
  const list = getList(false);
  if (!list.length) return;
  // 마지막 문제에서 '다음'을 누르면 1번으로 돌지 않고 완료 카드 표시
  if (step > 0 && state.idx >= list.length - 1) {
    renderComplete(document.getElementById("content-area"));
    return;
  }
  let idx = state.idx + step;
  if (idx < 0) idx = 0;
  if (idx >= list.length) idx = list.length - 1;
  state.idx = idx;
  state.lastQid = getQId(list[idx]);
  state.lastQids[state.subj] = state.lastQid;
  localStorage.setItem("mok_last", state.lastQid);
  localStorage.setItem("mok_lasts", JSON.stringify(state.lastQids));
  render();
  scrollToSolve();
}

// 학습 완료 카드
function renderComplete(cArea) {
  cArea.innerHTML = `
    <div class="card" style="text-align:center; padding:40px 24px;">
      <div style="width:56px;height:56px;margin:0 auto 16px;border-radius:50%;background:var(--green-soft);display:flex;align-items:center;justify-content:center;font-size:30px;color:var(--green);">✓</div>
      <div style="font-size:1.3rem;font-weight:bold;margin-bottom:6px;">학습 완료!</div>
      <div style="color:var(--muted);margin-bottom:24px;line-height:1.6;">선택하신 범위의 마지막 문제까지<br>모두 푸셨습니다.</div>
      <div style="display:flex;flex-direction:column;gap:8px;max-width:280px;margin:0 auto;">
        <button class="nav-btn primary" onclick="restartStudy()">처음부터 다시</button>
        <button class="nav-btn" onclick="retryWrong()">틀린 것만 다시 풀기</button>
        <button class="nav-btn" style="color:var(--muted);" onclick="endStudy()">학습 종료</button>
      </div>
    </div>`;
  updateDashboard();
  scrollToSolve();
}
function restartStudy() { state.idx = 0; state.pendingResume = false; render(); scrollToSolve(); }
function endStudy() {
  const cArea = document.getElementById("content-area");
  cArea.innerHTML = `
    <div class="card" style="text-align:center; padding:40px 24px;">
      <div style="font-size:1.2rem; font-weight:bold; margin-bottom:6px;">학습을 종료했습니다</div>
      <div style="color:var(--muted); margin-bottom:22px; line-height:1.6;">위 대시보드에서 진도와 정답률을<br>확인할 수 있어요.</div>
      <button class="nav-btn primary" style="max-width:240px; margin:0 auto;" onclick="restartStudy()">다시 시작</button>
    </div>`;
