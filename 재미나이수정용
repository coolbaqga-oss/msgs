function normalize(s) { return (s || "").toLowerCase().trim(); }
function formatDate(d) { return d.toISOString().split("T")[0]; }
function todayStr() { return formatDate(new Date()); }
function addDays(date, days) { const d = new Date(date); d.setDate(d.getDate() + days); return d; }

function shuffleInPlace(a) {
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
function mixByYear(list, count) {
  const groups = new Map();
  list.forEach(q => {
    const y = q.year || "미상";
    if (!groups.has(y)) groups.set(y, []);
    groups.get(y).push(q);
  });
  const years = Array.from(groups.keys());
  years.forEach(y => shuffleInPlace(groups.get(y)));
  shuffleInPlace(years);
  const total = count || list.length;
  const out = [];
  while (out.length < total) {
    let added = false;
    for (let i = 0; i < years.length && out.length < total; i++) {
      const y = years[i];
      const arr = groups.get(y);
      if (arr && arr.length) {
        out.push(arr.pop());
        added = true;
      }
    }
    if (!added) break;
    shuffleInPlace(years);
  }
  return out;
}

function getQId(q) {
  const head = (q.q || "").replace(/\s+/g, "").slice(0, 20);
  return `${q.year}-${q.subj}-${q.no || head}`;
}
function getAttempt(qid) {
  if (stats[qid]) return stats[qid];
  if (progress[qid] === "O") return { c: 1, t: 1 };
  if (progress[qid] === "X") return { c: 0, t: 1 };
  return { c: 0, t: 0 };
}
function isDue(qid) {
  const s = srs[qid];
  if (!s || !s.due) return false;
  return s.due <= todayStr();
}
function saveAll() {
  localStorage.setItem("mok_prog", JSON.stringify(progress));
  localStorage.setItem("mok_wrong", JSON.stringify(wrongNotes));
  localStorage.setItem("mok_srs", JSON.stringify(srs));
  localStorage.setItem("mok_bm", JSON.stringify(bookmarks));
  localStorage.setItem("mok_stats", JSON.stringify(stats));
  localStorage.setItem("mok_streak", JSON.stringify(streakInfo));
}
function invalidateList() { listCache.key = ""; }

function getTopWrongIds(n) {
  const entries = Object.entries(wrongNotes)
    .map(([qid, v]) => ({ qid, count: v.count || 0 }))
    .filter(x => x.count > 0)
    .sort((a, b) => b.count - a.count);
  return new Set(entries.slice(0, n).map(x => x.qid));
}
function getWeakIds(list) {
  if (!list.length) return new Set();
  const arr = list.map(q => {
    const qid = getQId(q);
    const st = getAttempt(qid);
    const acc = st.t ? st.c / st.t : 0;
    return { qid, acc };
  }).sort((a, b) => a.acc - b.acc);
  const n = Math.max(1, Math.ceil(arr.length * 0.2));
  return new Set(arr.slice(0, n).map(x => x.qid));
}

function buildList(forExam) {
  const search = normalize(state.search);
  let temp = allQuestions.filter(q => {
    if (!q || !q.q) return false;
    const isFreq = q.year === "빈출";
    if (state.freqOnly) {
      if (!isFreq) return false;
    } else if (isFreq) return false;

    const yMatch = state.years.length === 0 || state.years.includes(q.year);
    const sMatch = state.subj === "all" || q.subj === state.subj;
    if (!yMatch || !sMatch) return false;

    if (search) {
      const blob = (q.q + " " + (q.opts || []).join(" ") + " " + (q.e || "")).toLowerCase();
      if (!blob.includes(search)) return false;
    }

    if (!forExam) {
      const qid = getQId(q);
      if (state.dueOnly && !isDue(qid)) return false;
      if (state.wrongOnly && progress[qid] !== "X") return false;
      if (state.bookmarkOnly && !bookmarks[qid]) return false;
      if (state.tagFilter !== "all" && wrongNotes[qid]?.tag !== state.tagFilter) return false;
    }
    return true;
  });

  if (!forExam) {
    if (state.wrongnoteOnly) {
      const set = getTopWrongIds(3);
      temp = temp.filter(q => set.has(getQId(q)));
    }
    if (state.weakOnly) {
      const set = getWeakIds(temp);
      temp = temp.filter(q => set.has(getQId(q)));
    }
  }
  return temp;
}

function getList(forExam) {
  const key = JSON.stringify({
    years: state.years.slice().sort(),
    subj: state.subj, freqOnly: state.freqOnly, wrongOnly: state.wrongOnly,
    shuffled: state.shuffled, bookmarkOnly: state.bookmarkOnly,
    search: state.search, tagFilter: state.tagFilter,
    wrongnoteOnly: state.wrongnoteOnly, weakOnly: state.weakOnly, dueOnly: state.dueOnly,
    forExam
  });
  if (listCache.key !== key) {
    let list = buildList(forExam);
    if (state.shuffled) list = shuffleInPlace(list);
    listCache = { key, list };
  }
  return listCache.list;
}

function buildExamPool() {
  let temp = allQuestions.filter(q => q && q.q);
  if (state.freqOnly) temp = temp.filter(q => q.year === "빈출");
  else temp = temp.filter(q => q.year !== "빈출");
  if (state.subj !== "all") temp = temp.filter(q => q.subj === state.subj);

  if (state.dueOnly) temp = temp.filter(q => isDue(getQId(q)));
  if (state.wrongOnly) temp = temp.filter(q => progress[getQId(q)] === "X");
  if (state.bookmarkOnly) temp = temp.filter(q => bookmarks[getQId(q)]);
  if (state.tagFilter !== "all") temp = temp.filter(q => wrongNotes[getQId(q)]?.tag === state.tagFilter);
  if (state.wrongnoteOnly) {
    const set = getTopWrongIds(3);
    temp = temp.filter(q => set.has(getQId(q)));
  }
  if (state.weakOnly) {
    const set = getWeakIds(temp);
    temp = temp.filter(q => set.has(getQId(q)));
  }
  return temp;
}

function getYearList() {
  return [...new Set(allQuestions.filter(q => q.year !== "빈출").map(q => q.year))].sort();
}
function buildYearlyPoolAll() {
  if (!state.yearlyYears.length) return [];
  let temp = allQuestions.filter(q => q && q.q && q.year !== "빈출" && state.yearlyYears.includes(q.year));
  if (state.subj !== "all") temp = temp.filter(q => q.subj === state.subj);
  return temp;
}

