  scrollToSolve();
}
function retryWrong() {
  state.wrongOnly = true; invalidateList();
  const list = getList(false);
  if (!list.length) {
    state.wrongOnly = false; invalidateList();
    showToast("틀린 문제가 없습니다.");
    state.idx = 0; state.pendingResume = false; render();
    return;
  }
  const b = document.querySelector('.chip[data-filter="wrong"]');
  if (b) b.classList.add("on");
  state.idx = 0; state.pendingResume = false; render();
  scrollToSolve();
}

function toggleAdv(e) {
  if (e) e.stopPropagation();
  const p = document.getElementById("adv-panel");
  p.classList.toggle("show");
}

function toggleBm(qid) {
  bookmarks[qid] = !bookmarks[qid];
  saveAll();
  render();
}

function showToast(m, type) {
  const t = document.getElementById("toast");
  t.textContent = m;
  t.className = "show" + (type ? " " + type : "");
  setTimeout(() => t.className = "", 1400);
}

function updateStats(qid, isCorrect) {
  if (!stats[qid]) stats[qid] = { c: 0, t: 0 };
  stats[qid].t += 1;
  if (isCorrect) stats[qid].c += 1;
}

function updateStreak() {
  const today = todayStr();
  if (streakInfo.last === today) return;
  const yesterday = formatDate(addDays(new Date(), -1));
  if (streakInfo.last === yesterday) streakInfo.streak += 1;
  else streakInfo.streak = 1;
  streakInfo.last = today;
}

function updateDashboard() {
  const base = allQuestions.filter(q => q.year !== "빈출");
  const bySubj = { "성경": { c: 0, t: 0 }, "교회사": { c: 0, t: 0 }, "헌법": { c: 0, t: 0 } };
  let total = 0, answered = 0;

  base.forEach(q => {
    const qid = getQId(q);
    const st = getAttempt(qid);
    if (st.t > 0) answered++;
    total++;
    if (bySubj[q.subj]) {
      bySubj[q.subj].c += st.c;
      bySubj[q.subj].t += st.t;
    }
  });

  const progressPct = total ? Math.round((answered / total) * 100) : 0;
  const dueCount = Object.keys(srs).filter(qid => isDue(qid)).length;

  const acc = obj => obj.t ? Math.round((obj.c / obj.t) * 100) : 0;
  document.getElementById("score-bible").textContent = acc(bySubj["성경"]) + "%";
  document.getElementById("score-history").textContent = acc(bySubj["교회사"]) + "%";
  document.getElementById("score-law").textContent = acc(bySubj["헌법"]) + "%";
  document.getElementById("stat-progress").textContent = progressPct + "%";
  document.getElementById("stat-streak").textContent = (streakInfo.streak || 0) + "일";
  document.getElementById("stat-due").textContent = dueCount;
}

function saveSRS(qid, success) {
  const today = new Date();
  const prev = srs[qid] || { interval: 0 };
  let interval = success ? (prev.interval ? Math.min(prev.interval * 2, 60) : 1) : 1;
  let due = success ? addDays(today, interval) : today;
  srs[qid] = { due: formatDate(due), interval };
}

function setTag(qid, tag) {
  if (!wrongNotes[qid]) wrongNotes[qid] = { count: 0 };
  wrongNotes[qid].tag = tag;
  saveAll();
  invalidateList();
  showToast(`'${tag}' 태그가 설정되었습니다.`);
  moveIdx(1);
}

function saveWrong(qid) {
  if (!wrongNotes[qid]) wrongNotes[qid] = { count: 0 };
  wrongNotes[qid].count += 1;
}

// 화면 설정(필터·모드·토글·검색)을 현재 state에 맞춰 UI에 다시 반영
function syncAllUI() {
  updateSubjUI();
  updateYearUI();
  const fmap = { due: "dueOnly", wrong: "wrongOnly", shuffle: "shuffled", bookmark: "bookmarkOnly", freq: "freqOnly", wrongnote: "wrongnoteOnly", weak: "weakOnly" };
  document.querySelectorAll(".chip[data-filter]").forEach(btn => {
    btn.classList.toggle("on", !!state[fmap[btn.dataset.filter]]);
  });
  document.querySelectorAll(".mode-tab").forEach(btn => {
    btn.classList.toggle("on", btn.dataset.mode === state.mode);
  });
  const sb = document.getElementById("search-box");
  if (sb) sb.value = state.search || "";
  const tf = document.getElementById("tag-filter");
  if (tf) tf.value = state.tagFilter || "all";
  syncFilterVisibility();
}

function backupProgress() {
  const view = {
    subj: state.subj, years: state.years, mode: state.mode,
    freqOnly: state.freqOnly, wrongOnly: state.wrongOnly, shuffled: state.shuffled,
    bookmarkOnly: state.bookmarkOnly, dueOnly: state.dueOnly, tagFilter: state.tagFilter,
    wrongnoteOnly: state.wrongnoteOnly, weakOnly: state.weakOnly, search: state.search,
    examCount: state.examCount, yearlyYears: state.yearlyYears, idx: state.idx
  };
  const data = { progress, wrongNotes, srs, bookmarks, stats, streakInfo,
                 lastQid: state.lastQid, lastQids: state.lastQids, view,
                 savedAt: new Date().toISOString() };
  const blob = new Blob([JSON.stringify(data)], { type: "application/json" });
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = "mok_backup.json";
  a.click();
  URL.revokeObjectURL(a.href);
  localStorage.setItem("mok_lastbackup", new Date().toISOString());
  updateBackupBadge();
  showToast("백업 파일이 저장되었습니다.");
}

function restoreProgress() {
  document.getElementById("restore-file").click();
}
  
function refreshApp() {
  location.reload();
}

function handleRestore(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = () => {
    try {
      const data = JSON.parse(reader.result);
      progress = data.progress || {};
      wrongNotes = data.wrongNotes || {};
      srs = data.srs || {};
      bookmarks = data.bookmarks || {};
      stats = data.stats || {};
      streakInfo = data.streakInfo || { last: "", streak: 0 };

      // 과목별 이어풀기 위치
      if (data.lastQids && typeof data.lastQids === "object") state.lastQids = data.lastQids;

      // 화면 설정(필터·모드·랜덤섞기 등) 복원 — 구버전 백업엔 view가 없으니 건너뜀
      if (data.view) {
        const v = data.view;
        if (typeof v.subj === "string") state.subj = v.subj;
        if (Array.isArray(v.years)) state.years = v.years;
        if (typeof v.mode === "string") state.mode = v.mode;
        state.freqOnly = !!v.freqOnly;
        state.wrongOnly = !!v.wrongOnly;
        state.shuffled = !!v.shuffled;
        state.bookmarkOnly = !!v.bookmarkOnly;
        state.dueOnly = !!v.dueOnly;
        state.tagFilter = v.tagFilter || "all";
        state.wrongnoteOnly = !!v.wrongnoteOnly;
        state.weakOnly = !!v.weakOnly;
        state.search = v.search || "";
        if (typeof v.examCount === "number") state.examCount = v.examCount;
        if (Array.isArray(v.yearlyYears)) state.yearlyYears = v.yearlyYears;
        if (typeof v.idx === "number") state.idx = v.idx;
      }

      if (data.lastQid) {                       // 이어풀기 위치 복원
        state.lastQid = data.lastQid;
        localStorage.setItem("mok_last", data.lastQid);
      }
      state.pendingResume = true;               // 보던 문제로 복귀
      localStorage.setItem("mok_lasts", JSON.stringify(state.lastQids));

      saveAll();
      invalidateList();
      syncAllUI();                              // 칩·토글·모드·검색창을 복원된 설정에 맞춤
      render();
      showToast("복원이 완료되었습니다.");
    } catch {
      showToast("복원 실패: 파일을 확인하세요.");
    }
  };
  reader.readAsText(file);
}

function openResetMenu() { document.getElementById("reset-modal").classList.add("show"); }
function closeResetMenu() { document.getElementById("reset-modal").classList.remove("show"); }
function closeResetBg(e) { if (e.target.id === "reset-modal") closeResetMenu(); }

// 점수만 초기화 — 정답률·진도·통계·연속일·복습 일정만 0. 오답노트·별표는 유지.
function resetScores() {
  if (!confirm("정답률·진도·통계·복습 일정을 초기화할까요?\n(오답노트와 별표는 그대로 유지됩니다)")) return;
  progress = {};
  srs = {};
  stats = {};
  streakInfo = { last: "", streak: 0 };
  state.lastQid = null;
  localStorage.removeItem("mok_last");
  saveAll();
  invalidateList();
  closeResetMenu();
  state.idx = 0;
  state.pendingResume = false;
  render();
  updateDashboard();
  showToast("점수를 초기화했습니다.");
}

// 전체 초기화 — 오답노트·별표까지 모든 기록 삭제.
function resetAll() {
  if (!confirm("오답노트·별표까지 모든 기록을 삭제합니다.\n정말 진행할까요? (되돌릴 수 없습니다)")) return;
  progress = {};
  wrongNotes = {};
  srs = {};
  bookmarks = {};
  stats = {};
  streakInfo = { last: "", streak: 0 };
  state.lastQid = null;
  localStorage.removeItem("mok_last");
  saveAll();
  invalidateList();
  closeResetMenu();
  state.idx = 0;
  state.pendingResume = false;
  render();
  updateDashboard();
  showToast("전체 초기화 완료");
}

function renderYearChips() {
  const wrap = document.getElementById("year-chips");
  const years = getYearList();
  wrap.innerHTML = `<button class="chip year-f on" data-year="all">전체 연도</button>` +
    years.map(y => `<button class="chip year-f" data-year="${y}">${y}</button>`).join("");
}

function updateYearUI() {
  document.querySelectorAll(".year-f").forEach(b => {
    const y = b.dataset.year;
    if (y === "all") b.classList.toggle("on", state.years.length === 0);
    else b.classList.toggle("on", state.years.includes(y));
  });
}

function updateSubjUI() {
  document.querySelectorAll(".subj-f").forEach(b => {
    b.classList.toggle("on", b.dataset.subj === state.subj);
  });
}

window.onload = () => {
  renderYearChips();

  document.querySelectorAll(".year-f").forEach(btn => {
    btn.onclick = () => {
      const y = btn.dataset.year;
      if (y === "all") state.years = [];
      else {
        if (state.years.includes(y)) state.years = state.years.filter(v => v !== y);
        else state.years.push(y);
      }
      updateYearUI();
      state.pendingResume = true;
      invalidateList();
      render();
    };
  });

  document.querySelectorAll(".subj-f").forEach(btn => {
    btn.onclick = () => {
      state.subj = btn.dataset.subj;
      updateSubjUI();
      state.pendingResume = true;
      invalidateList();
      render();
    };
  });

  const filterMap = {
    due: "dueOnly",
    wrong: "wrongOnly",
    shuffle: "shuffled",
    bookmark: "bookmarkOnly",
    freq: "freqOnly",
    wrongnote: "wrongnoteOnly",
    weak: "weakOnly"
  };

  document.querySelectorAll(".chip[data-filter]").forEach(btn => {
    btn.onclick = () => {
      const key = filterMap[btn.dataset.filter];
      state[key] = !state[key];
      btn.classList.toggle("on");
      if (btn.dataset.filter === "shuffle") {
        state.idx = 0;
        state.pendingResume = false;
      } else {
        state.pendingResume = true;
      }
      invalidateList();
      render();
    };
  });

  document.getElementById("tag-filter").onchange = e => {
    state.tagFilter = e.target.value;
    state.pendingResume = true;
    invalidateList();
    render();
  };

  let searchTimer = null;
  document.getElementById("search-box").oninput = e => {
    const val = e.target.value.trim();
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
      state.search = val;
      state.pendingResume = true;
      invalidateList();
      render();
    }, 250);
  };

  document.querySelectorAll(".mode-tab").forEach(btn => {
    btn.onclick = () => {
      document.querySelectorAll(".mode-tab").forEach(b => b.classList.remove("on"));
      btn.classList.add("on");
      state.mode = btn.dataset.mode;
      state.pendingResume = true;
      if (state.mode === "yearly") {
        state.freqOnly = false;
        const freqBtn = document.querySelector('[data-filter="freq"]');
        if (freqBtn) freqBtn.classList.remove("on");
      }
      render();
      scrollToSolve();
    };
  });

  document.addEventListener("click", e => {
    const wrap = document.querySelector(".adv-wrap");
    const panel = document.getElementById("adv-panel");
    if (wrap && panel && !wrap.contains(e.target)) panel.classList.remove("show");
  });

  // 키보드 단축키 (외장 키보드) — 입력칸 포커스 중이거나 모달 열렸을 땐 무시
  document.addEventListener("keydown", e => {
    const tag = (e.target.tagName || "").toLowerCase();
    if (tag === "input" || tag === "textarea" || tag === "select") return;
    if (e.metaKey || e.ctrlKey || e.altKey) return;
    const modal = document.getElementById("changelog-modal");
    if (modal && modal.classList.contains("show")) return;
    const rmodal = document.getElementById("reset-modal");
    if (rmodal && rmodal.classList.contains("show")) return;

    const answered = !!document.querySelector(".opt.answered");

    if (state.mode === "study") {
      if (/^[1-9]$/.test(e.key) && !answered) {
        const opts = document.querySelectorAll("#options-area .opt");
        const i = parseInt(e.key, 10) - 1;
        if (opts[i]) { e.preventDefault(); checkAns(i); }
      } else if (e.key === "ArrowRight" || (e.key === "Enter" && answered)) {
        e.preventDefault(); moveIdx(1);
      } else if (e.key === "ArrowLeft") {
        e.preventDefault(); moveIdx(-1);
      }
    } else if (state.mode === "exam" && exam.active) {
      if (/^[1-9]$/.test(e.key)) {
        const opts = document.querySelectorAll("#options-area .opt");
        const i = parseInt(e.key, 10) - 1;
        if (opts[i]) { e.preventDefault(); pickExam(i); }
      }
    }
  });

  applyFont();                  // 저장된 글자 크기 적용
  updateBackupBadge();          // 마지막 백업 시점 표시
  updateYearUI();
  updateSubjUI();
  state.pendingResume = true;  // 앱 재진입 시 마지막 본 문제로 복귀
  render();
  updateDashboard();
  updateVerBadge();             // 헤더 버전 옆 🆕 점
  showUpdateBannerIfNeeded();   // 새 버전이면 상단 배너 1회
};
</script>
